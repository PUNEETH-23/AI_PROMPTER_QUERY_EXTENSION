{
  "manifest_version": 3,
  "name": "AI Prompt Generator",
  "version": "1.0",
  "description": "Generate structured AI prompts",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api-inference.huggingface.co/*"],
  "background": {
    "service_worker": "background.js"
  }
}